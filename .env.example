# MedAdapt - Environment Variables

# AI Engine Configuration (Hỗ trợ Google Gemini hoặc Anthropic Claude)
# Khuyên dùng Google Gemini API (Lấy key miễn phí tại: https://aistudio.google.com/)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-pro

# Hoặc nếu dùng Anthropic Claude:
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# AI Performance & Tiering Optimization
AI_MAX_RETRIES=4
AI_PROMPT_CACHE=true
CLAUDE_MODEL_FAST=claude-3-5-haiku-20241022
CLAUDE_MODEL_SMART=claude-sonnet-4-20250514
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_SMART=gemini-2.5-pro

# Notion Integration
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxx
NOTION_PAGE_ID=

# Server
PORT=3000
HOST=localhost
DB_PATH=./data/medadapt.db

# Schedule (7:00 AM daily)
DAILY_TEST_CRON=0 7 * * *

# App
DEFAULT_DIAGNOSTIC_QUESTIONS=40
DEFAULT_DAILY_QUESTIONS=12
